# Resend (email notifications) — get your key at resend.com, verify domain beachhousemoving.xyz
RESEND_API_KEY=
RESEND_FROM_EMAIL=quotes@beachhousemoving.xyz
RESEND_TO_EMAIL=beachhousemoving@gmail.com

# Google Analytics (via GTM — this ID is used in tracking utilities, not for direct gtag init)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Places API — set when GBP is verified and showing in Maps search
# To find your Place ID: maps.google.com → search "Beach House Moving" → share → copy the CID
# Format: ChIJ...
NEXT_PUBLIC_GOOGLE_PLACE_ID=
GOOGLE_PLACES_API_KEY=

# Site URL — must be https://beachhousemoving.xyz in Vercel Production
NEXT_PUBLIC_SITE_URL=https://beachhousemoving.xyz
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
