# Resend (email notifications) — get your key at resend.com, verify domain beachhousemoving.xyz
RESEND_API_KEY=
RESEND_FROM_EMAIL=quotes@beachhousemoving.xyz
RESEND_TO_EMAIL=beachhousemoving@gmail.com

# Second recipient for quote/contact notifications (optional — leave blank if only one recipient needed)
# Add your personal email here to receive copies alongside beachhousemoving@gmail.com
RESEND_TO_EMAIL_2=

# Google Analytics (via GTM — this ID is used in tracking utilities, not for direct gtag init)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Places API (New) — live reviews. Enable "Places API (New)" + billing.
# Place ID is the ChIJ... token (NOT a CID / "0x..." hex). Find it in the Google
# SEARCH knowledge panel source, or via Places Text Search (New).
NEXT_PUBLIC_GOOGLE_PLACE_ID=ChIJf0UKYLeaxAIReXzK9LBOUFw
GOOGLE_PLACES_API_KEY=

# Site URL — must be https://beachhousemoving.xyz in Vercel Production
NEXT_PUBLIC_SITE_URL=https://beachhousemoving.xyz
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
